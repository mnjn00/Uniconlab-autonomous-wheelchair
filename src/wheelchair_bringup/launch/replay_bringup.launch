<launch>
  <!-- Canonical ROS 1 bag replay consumers. Playback is external; this graph has no actuation sink. -->
  <arg name="use_sim_time" default="true"/>
  <arg name="route_policy" default="$(find wheelchair_navigation)/config/hanyang_routes.yaml"/>
  <arg name="route_policy_sha256" default="3861e21a6360fe7e32f833f867acb7dd50dccbf45a67f17d93699cea9cbe13c6"/>
  <arg name="route_safety_policy" default="$(find wheelchair_route_safety)/config/route_safety_sim.yaml"/>
  <arg name="route_safety_policy_sha256" default="6c9496802956c09ec5eb0cb8a02baf417ea426ce10a6409c33bd9532869a79c9"/>
  <arg name="localization_policy" default="$(find wheelchair_navigation)/config/localization_confidence.yaml"/>
  <arg name="localization_policy_sha256" default="4444444444444444444444444444444444444444444444444444444444444444"/>
  <arg name="collision_policy" default="$(find wheelchair_safety)/config/collision_policy.yaml"/>
  <arg name="collision_policy_sha256" default="5850bb0cd84bc04f4f9cdc78cd347640a3f60f66241ad3f37c196ad63cbeba18"/>
  <arg name="slope_policy" default="$(find wheelchair_safety)/config/slope_policy.yaml"/>
  <arg name="slope_policy_sha256" default="171d0febf5f3a691d1500d7b7839ef8f4a04637545b79dcb95d825bead7f6d0d"/>
  <arg name="map_id" default="hanyang_aegimun_loop"/>
  <arg name="map_sha256" default="c89d791f71fe3d1705ae04724acf8ff6ba0ccc351fc162fe996982f9469a0278"/>
  <arg name="route_sha256" default="adf11b569c043da3b617f908ad56b2bc0ca6d32a32c6dd83a33a322045a4d672"/>

  <param name="/use_sim_time" value="true"/>
  <param name="/wheelchair_bringup/profile" value="replay"/>
  <param name="/replay_only" value="true"/>
  <param name="/hardware_motion_authorized" value="false"/>
  <param name="/passenger_operation_authorized" value="false"/>
  <param name="/wheelchair_bringup/startup_mode" value="DISARMED"/>
  <param name="/wheelchair_bringup/localization_candidate_policy" value="BLOCKED_UNLESS_QUALIFIED"/>
  <param name="/wheelchair_bringup/map_sha256" value="$(arg map_sha256)"/>
  <param name="/wheelchair_bringup/route_sha256" value="$(arg route_sha256)"/>
  <param name="/wheelchair_bringup/policies/route_sha256" value="$(arg route_policy_sha256)"/>
  <param name="/wheelchair_bringup/policies/route_safety_sha256" value="$(arg route_safety_policy_sha256)"/>
  <param name="/wheelchair_bringup/policies/localization_sha256" value="$(arg localization_policy_sha256)"/>
  <param name="/wheelchair_bringup/policies/collision_sha256" value="$(arg collision_policy_sha256)"/>
  <param name="/wheelchair_bringup/policies/slope_sha256" value="$(arg slope_policy_sha256)"/>
  <rosparam command="load" file="$(find wheelchair_bringup)/config/params.yaml"/>
  <rosparam command="load" file="$(find wheelchair_bringup)/config/runtime_modes.yaml" ns="runtime_modes"/>

  <include file="$(find wheelchair_perception)/launch/perception.launch">
    <arg name="source_profile" value="replay"/>
    <arg name="replay_cloud_topic" value="/sensors/lidar/points"/>
    <arg name="replay_imu_topic" value="/sensors/imu/data"/>
  </include>

  <!-- Candidate adapter is disabled; the independent safety guard owns fail-closed status. -->
  <include file="$(find wheelchair_navigation)/launch/localization.launch">
    <arg name="enabled" value="false"/>
    <arg name="source" value=""/>
    <arg name="map_id" value="$(arg map_id)"/>
    <arg name="map_sha256" value="$(arg map_sha256)"/>
    <arg name="policy_sha256" value="$(arg localization_policy_sha256)"/>
    <arg name="base_model_enabled" value="false"/>
    <arg name="amcl_enabled" value="false"/>
    <arg name="cartographer_noetic_enabled" value="false"/>
  </include>

  <include file="$(find wheelchair_navigation)/launch/route_manager.launch">
    <arg name="manifest" value="$(arg route_policy)"/>
  </include>

  <node pkg="wheelchair_route_safety" type="route_safety.py"
        name="wheelchair_route_safety" output="screen" required="true">
    <param name="config_path" value="$(arg route_safety_policy)"/>
    <param name="expected_config_sha256" value="$(arg route_safety_policy_sha256)"/>
  </node>

  <include file="$(find wheelchair_decision)/launch/decision.launch">
    <arg name="route_manifest" value="$(arg route_policy)"/>
  </include>

  <include file="$(find wheelchair_navigation)/launch/navigation.launch">
    <arg name="use_sim_time" value="true"/>
    <arg name="cmd_vel_nav_topic" value="/cmd_vel_nav"/>
  </include>

  <!-- Sole replay command path ends on a namespaced shadow topic with no subscriber sink. -->
  <include file="$(find wheelchair_safety)/launch/safety.launch">
    <arg name="profile" value="replay"/>
    <arg name="input_cmd_topic" value="/cmd_vel_nav"/>
    <arg name="output_cmd_topic" value="/shadow/cmd_vel_safe"/>
    <arg name="collision_policy" value="$(arg collision_policy)"/>
    <arg name="slope_policy" value="$(arg slope_policy)"/>
    <arg name="slope_operation_mode" value="replay"/>
    <arg name="slope_stationary_calibration_enabled" value="false"/>
    <arg name="slope_transform_label" value="unverified_replay"/>
    <arg name="slope_transform_verified" value="false"/>
    <arg name="localization_policy" value="$(arg localization_policy)"/>
    <arg name="localization_policy_file_sha256" value="7c876d311ca3cd52881c93af0f3f8dc9410b64f090ac856052781ad123031829"/>
    <arg name="localization_map" value="$(find wheelchair_navigation)/../../data/hanyang_aegimun_loop/map.yaml"/>
    <arg name="localization_map_file_sha256" value="9f36ab2d3d35a667996570b45babb7cb3ba8bd1e706a971af22603da1220e7ff"/>
    <arg name="localization_map_image_sha256" value="$(arg map_sha256)"/>
  </include>

  <include file="$(find wheelchair_navigation)/launch/control_monitor.launch"/>

  <node pkg="wheelchair_bringup" type="incident_recorder.py"
        name="incident_recorder" args="--config $(find wheelchair_bringup)/config/observability.yaml"
        output="screen" required="false">
    <remap from="/cmd_vel_safe" to="/shadow/cmd_vel_safe"/>
    <rosparam param="identity_hashes" subst_value="true">
      map: $(arg map_sha256)
      route: $(arg route_sha256)
    </rosparam>
  </node>
</launch>
