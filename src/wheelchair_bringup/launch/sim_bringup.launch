<launch>
  <!-- Complete ROS 1 software-in-loop profile. Hardware and passenger authority remain false. -->
  <arg name="world" default="$(find wheelchair_gazebo)/worlds/wheelchair_rc_scenarios.world"/>
  <arg name="scenario" default="full_rc_matrix"/>
  <arg name="fault_id" default="normal"/>
  <arg name="seed" default="1701"/>
  <arg name="auto_start" default="false"/>
  <arg name="startup_readiness_timeout_sec" default="30.0"/>
  <arg name="scenario_direction" default="outbound"/>
  <arg name="gui" default="false"/>
  <arg name="headless" default="true"/>
  <arg name="paused" default="false"/>
  <arg name="use_sim_time" default="true"/>
  <arg name="spawn_x" default="0.44629311316521386"/>
  <arg name="spawn_y" default="0.2644224486717838"/>
  <arg name="spawn_z" default="0.10"/>
  <arg name="spawn_yaw" default="0.21401823367762954"/>
  <arg name="route_policy" default="$(find wheelchair_navigation)/config/hanyang_routes.yaml"/>
  <arg name="route_policy_sha256" default="3861e21a6360fe7e32f833f867acb7dd50dccbf45a67f17d93699cea9cbe13c6"/>
  <arg name="route_safety_policy" default="$(find wheelchair_route_safety)/config/route_safety_sim.yaml"/>
  <arg name="route_safety_policy_sha256" default="471bc90f8d52e341d2d6d287992fd26bf4224b776c57a057c82796bb0506eb60"/>
  <arg name="safety_manifest_sha256" default="93ca862dac1fbdd5914d93b2d2c325fe2742aef2a05289d44d0d4fe45989de57"/>
  <arg name="localization_policy" default="$(find wheelchair_navigation)/config/localization_confidence_sim.yaml"/>
  <arg name="localization_policy_sha256" default="5d84ea824c98a53639a480ed162a62f015600ca0a0460df7186d5839303d52e8"/>
  <arg name="collision_policy" default="$(find wheelchair_safety)/config/collision_policy.yaml"/>
  <arg name="collision_policy_sha256" default="e9397ad5993319d336149b8cdf9b3eb45da3574d3baa21654f0b544c2739cfd1"/>
  <arg name="slope_policy" default="$(find wheelchair_safety)/config/slope_policy.yaml"/>
  <arg name="slope_policy_sha256" default="171d0febf5f3a691d1500d7b7839ef8f4a04637545b79dcb95d825bead7f6d0d"/>
  <arg name="localization_source" default="base_model"/>
  <arg name="map_id" default="hanyang_aegimun_loop"/>
  <arg name="map_sha256" default="c89d791f71fe3d1705ae04724acf8ff6ba0ccc351fc162fe996982f9469a0278"/>
  <arg name="route_sha256" default="adf11b569c043da3b617f908ad56b2bc0ca6d32a32c6dd83a33a322045a4d672"/>
  <arg name="route_truth" default="$(find wheelchair_gazebo)/config/route_truth_outbound.yaml"/>
  <arg name="route_truth_sha256" default="ff3114d37755772d91c3d683c2b74785e5f86385608308ecaec9445e9a245b70"/>
  <arg name="scenario_sha256" default=""/>
  <arg name="a13_sha256" default="f7984b85d8ccf7d0f481f7daa73135109440209ca8c62847c57095da47604123"/>
  <arg name="claim_tag" default="SIMULATION_ONLY"/>

  <param name="/use_sim_time" value="true"/>
  <param name="/wheelchair_bringup/profile" value="sim"/>
  <param name="/simulation_only" value="true"/>
  <param name="/hardware_motion_authorized" value="false"/>
  <param name="/passenger_operation_authorized" value="false"/>
  <param name="/wheelchair_bringup/startup_mode" value="DISARMED"/>
  <param name="/wheelchair_bringup/map_id" value="$(arg map_id)"/>
  <param name="/wheelchair_bringup/map_sha256" value="$(arg map_sha256)"/>
  <param name="/wheelchair_bringup/route_sha256" value="$(arg route_sha256)"/>
  <param name="/wheelchair_bringup/policies/route_sha256" value="$(arg route_policy_sha256)"/>
  <param name="/wheelchair_bringup/policies/route_safety_sha256" value="$(arg route_safety_policy_sha256)"/>
  <param name="/wheelchair_bringup/policies/localization_sha256" value="$(arg localization_policy_sha256)"/>
  <param name="/wheelchair_bringup/policies/collision_sha256" value="$(arg collision_policy_sha256)"/>
  <param name="/wheelchair_bringup/policies/slope_sha256" value="$(arg slope_policy_sha256)"/>
  <param name="/wheelchair_bringup/safety_manifest_sha256" value="$(arg safety_manifest_sha256)"/>
  <param name="/wheelchair_bringup/route_truth_sha256" value="$(arg route_truth_sha256)"/>
  <param name="/wheelchair_bringup/scenario_sha256" value="$(arg scenario_sha256)"/>
  <param name="/wheelchair_bringup/a13_sha256" value="$(arg a13_sha256)"/>
  <param name="/wheelchair_bringup/claim_tag" value="$(arg claim_tag)"/>
  <rosparam command="load" file="$(find wheelchair_bringup)/config/params.yaml"/>
  <rosparam command="load" file="$(find wheelchair_bringup)/config/runtime_modes.yaml" ns="runtime_modes"/>

  <include file="$(find wheelchair_gazebo)/launch/rc_sim.launch">
    <arg name="world" value="$(arg world)"/>
    <arg name="scenario" value="$(arg scenario)"/>
    <arg name="seed" value="$(arg seed)"/>
    <arg name="gui" value="$(arg gui)"/>
    <arg name="headless" value="$(arg headless)"/>
    <arg name="paused" value="$(arg paused)"/>
    <arg name="use_sim_time" value="true"/>
    <arg name="spawn_x" value="$(arg spawn_x)"/>
    <arg name="spawn_y" value="$(arg spawn_y)"/>
    <arg name="spawn_z" value="$(arg spawn_z)"/>
    <arg name="spawn_yaw" value="$(arg spawn_yaw)"/>
    <arg name="route_policy" value="$(arg route_policy)"/>
    <arg name="route_safety_policy" value="$(arg route_safety_policy)"/>
    <arg name="localization_policy" value="$(arg localization_policy)"/>
    <arg name="collision_policy" value="$(arg collision_policy)"/>
    <arg name="slope_policy" value="$(arg slope_policy)"/>
  </include>

  <!-- Converts Gazebo truth into explicitly simulation-qualified, non-command evidence. -->
  <node pkg="wheelchair_gazebo" type="sim_evidence_bridge.py"
        name="sim_evidence_bridge" output="screen" required="true">
    <param name="controller_name" value="wheelchair_base_controller"/>
    <param name="map_origin_x" value="$(arg spawn_x)"/>
    <param name="map_origin_y" value="$(arg spawn_y)"/>
    <param name="map_origin_yaw" value="$(arg spawn_yaw)"/>
  </node>

  <include file="$(find wheelchair_perception)/launch/perception.launch">
    <arg name="source_profile" value="simulation"/>
    <arg name="simulation_cloud_topic" value="/sensors/lidar/points"/>
    <arg name="simulation_imu_topic" value="/sensors/imu/data"/>
  </include>

  <include file="$(find wheelchair_navigation)/launch/localization.launch">
    <arg name="enabled" value="true"/>
    <arg name="source" value="$(arg localization_source)"/>
    <arg name="map_id" value="$(arg map_id)"/>
    <arg name="map_sha256" value="$(arg map_sha256)"/>
    <arg name="policy_sha256" value="$(arg localization_policy_sha256)"/>
    <arg name="base_model_enabled" value="true"/>
    <arg name="base_model_pose_topic" value="/base_model/localization_pose"/>
    <arg name="base_model_diagnostic_topic" value="/base_model/localization_diagnostics"/>
  </include>

  <include file="$(find wheelchair_navigation)/launch/route_manager.launch">
    <arg name="manifest" value="$(arg route_policy)"/>
    <arg name="localization_pose_topic" value="/base_model/localization_pose"/>
  </include>

  <node pkg="wheelchair_route_safety" type="route_safety.py"
        name="wheelchair_route_safety" output="screen" required="true">
    <param name="config_path" value="$(arg route_safety_policy)"/>
    <param name="expected_config_sha256" value="$(arg route_safety_policy_sha256)"/>
  </node>

  <include file="$(find wheelchair_decision)/launch/decision.launch">
    <arg name="route_manifest" value="$(arg route_policy)"/>
  </include>

  <include file="$(find wheelchair_navigation)/launch/navigation.launch">
    <arg name="use_sim_time" value="true"/>
    <arg name="cmd_vel_nav_topic" value="/cmd_vel_nav"/>
  </include>

  <include file="$(find wheelchair_safety)/launch/safety.launch">
    <arg name="profile" value="sim"/>
    <arg name="input_cmd_topic" value="/cmd_vel_nav"/>
    <arg name="output_cmd_topic" value="/cmd_vel_safe"/>
    <arg name="collision_policy" value="$(arg collision_policy)"/>
    <arg name="slope_policy" value="$(arg slope_policy)"/>
    <arg name="slope_initial_route_zone_policy" value="simulation_allow"/>
    <arg name="slope_initial_route_zone_timeout_s" value="$(arg startup_readiness_timeout_sec)"/>
    <arg name="localization_policy" value="$(arg localization_policy)"/>
    <arg name="localization_policy_file_sha256" value="7b539d7fc276be0b702e7ad848dd38340ebec866dc9e4ddf4abffc65ce27bc80"/>
    <arg name="localization_map" value="$(find wheelchair_navigation)/../../data/hanyang_aegimun_loop/map.yaml"/>
    <arg name="localization_map_file_sha256" value="9f36ab2d3d35a667996570b45babb7cb3ba8bd1e706a971af22603da1220e7ff"/>
    <arg name="localization_map_image_sha256" value="$(arg map_sha256)"/>
    <arg name="localization_initialization_attempt_timeout_s" value="$(arg startup_readiness_timeout_sec)"/>
  </include>

  <include file="$(find wheelchair_navigation)/launch/control_monitor.launch"/>

  <node pkg="wheelchair_bringup" type="incident_recorder.py"
        name="incident_recorder" args="--config $(find wheelchair_bringup)/config/observability.yaml"
        output="screen" required="false">
    <rosparam param="identity_hashes" subst_value="true">
      map: $(arg map_sha256)
      route: $(arg route_sha256)
    </rosparam>
  </node>
  <!-- Explicit opt-in: this node can arm one simulated mission but owns no command topic. -->
  <node if="$(arg auto_start)" pkg="wheelchair_gazebo" type="rc_scenario_driver.py"
        name="rc_scenario_driver" output="screen" required="true">
    <param name="scenario" value="$(arg scenario)"/>
    <param name="seed" value="$(arg seed)"/>
    <param name="direction" value="$(arg scenario_direction)"/>
    <param name="route_truth" value="$(arg route_truth)"/>
    <param name="route_truth_sha256" value="$(arg route_truth_sha256)"/>
    <param name="scenario_sha256" value="$(arg scenario_sha256)"/>
    <param name="a13_sha256" value="$(arg a13_sha256)"/>
    <param name="claim_tag" value="$(arg claim_tag)"/>
    <param name="initial_pose_x" value="$(arg spawn_x)"/>
    <param name="initial_pose_y" value="$(arg spawn_y)"/>
    <param name="initial_pose_yaw" value="$(arg spawn_yaw)"/>
    <param name="readiness_timeout_sec" value="$(arg startup_readiness_timeout_sec)"/>
  </node>
  <!-- Fault effects are opt-in, bounded, and restricted by exact simulation preflight. -->
  <node if="$(arg auto_start)" pkg="wheelchair_gazebo" type="rc_fault_injector.py"
        name="rc_fault_injector" output="screen" required="false">
    <param name="fault_id" value="$(arg fault_id)"/>
  </node>
</launch>